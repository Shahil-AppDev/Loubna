# ─── Configuration email ────────────────────────────────────────────────────
# Option 1 : Resend (recommandé)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2 : SMTP (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=contact@loubna-abouz-manta.fr
SMTP_PASS=your_password

# Email de destination pour les messages de contact
CONTACT_EMAIL=contact@loubna-abouz-manta.fr

# ─── URL du site (production) ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://loubna-abouz-manta.fr

# ═══════════════════════════════════════════════════════════
# LOUBNA ABOUZ MANTA — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# ═══════════════════════════════════════════════════════════

# URL du site en production
NEXT_PUBLIC_SITE_URL=https://loubna-abouz-manta.fr

# ─── Option 1 : Formspree ───────────────────────────────────
# Créez un compte sur https://formspree.io et obtenez votre ID
NEXT_PUBLIC_FORMSPREE_ID=your_formspree_id

# ─── Option 2 : EmailJS ────────────────────────────────────
# Créez un compte sur https://emailjs.com
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# ─── Option 3 : Resend (API Route Next.js) ─────────────────
# Créez un compte sur https://resend.com
RESEND_API_KEY=re_your_resend_api_key
CONTACT_EMAIL_TO=contact@loubna-abouz-manta.fr

# ─── Google Analytics (optionnel) ──────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
